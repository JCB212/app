<configuration>

  <!-- Console (apenas em desenvolvimento) -->
  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss} %-5level [%thread] %logger{30} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Arquivo principal com rotação -->
  <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>sistema_fiscal.log</file>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>logs/sistema_fiscal.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>5MB</maxFileSize>
      <maxHistory>15</maxHistory>
      <totalSizeCap>75MB</totalSizeCap>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{40} - %msg%n%ex</pattern>
    </encoder>
  </appender>

  <!-- Arquivo exclusivo de erros -->
  <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
    <file>sistema_fiscal_erros.log</file>
    <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
      <level>WARN</level>
    </filter>
    <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
      <fileNamePattern>logs/erros.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
      <maxFileSize>5MB</maxFileSize>
      <maxHistory>30</maxHistory>
    </rollingPolicy>
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{40} - %msg%n%ex</pattern>
    </encoder>
  </appender>

  <!-- Nível DEBUG para pacote fiscal em desenvolvimento -->
  <logger name="br.com.infoativa.fiscal" level="DEBUG" additivity="false">
    <appender-ref ref="FILE"/>
    <appender-ref ref="ERROR_FILE"/>
    <appender-ref ref="CONSOLE"/>
  </logger>

  <!-- Reduzir verbosidade do JavaMail -->
  <logger name="jakarta.mail" level="WARN"/>
  <logger name="com.sun.mail" level="WARN"/>

  <root level="INFO">
    <appender-ref ref="FILE"/>
    <appender-ref ref="ERROR_FILE"/>
  </root>

</configuration>
